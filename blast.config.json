{
  "base_url": "http://localhost:3000/",
  "headers": {
    "Content-Type": "application/json"
  },
  "endpoints": [
    {
      "name": "health check",
      "method": "GET",
      "path": "/health",
      "headers": null,
      "body": null,
      "expect_status": 200,
      "extract": null,
      "tags": [
        "check",
        "seed"
      ]
    },
    {
      "name": "register user",
      "method": "POST",
      "path": "/api/v1/auth/register",
      "headers": null,
      "body": {
        "email": "{{fake.email}}",
        "password": "{{fake.password}}"
      },
      "expect_status": 201,
      "extract": null,
      "tags": null
    },
    {
      "name": "login",
      "method": "POST",
      "path": "/api/v1/auth/login",
      "headers": null,
      "body": {
        "email": "test@example.com",
        "password": "Seed1234!"
      },
      "expect_status": 200,
      "extract": {
        "access_token": "data.access_token"
      },
      "tags": [
        "check",
        "seed"
      ]
    }
  ]
}