{
  "name": "@pablo-clueless/blast-ts",
  "version": "0.1.2",
  "description": "Fast config-driven API load tester — TypeScript bindings for Blast",
  "main": "blast.js",
  "types": "blast.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Walon-Foundation/blast.git"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "validate.js",
    "validate.d.ts",
    "blast.js",
    "blast.d.ts",
    "README.md"
  ],
  "napi": {
    "name": "blast",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release --features node --cargo-flags=--no-default-features",
    "build:debug": "napi build --platform --features node --cargo-flags=--no-default-features",
    "test": "node --test test/index.ts",
    "report": "node test/report.mts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "optionalDependencies": {
    "@pablo-clueless/blast-linux-x64-gnu": "0.1.1",
    "@pablo-clueless/blast-darwin-arm64": "0.1.1",
    "@pablo-clueless/blast-win32-x64-msvc": "0.1.1"
  }
}
